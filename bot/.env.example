# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID (get by messaging @userinfobot on Telegram)
# This restricts the bot to only respond to YOU
OWNER_CHAT_ID=your_chat_id_here

# OpenAI API key (for receipt scanning with GPT-4o vision)
# Optional — receipt scanning won't work without this
OPENAI_API_KEY=your_openai_api_key_here

# News API key (free from https://newsapi.org)
# Optional — news summary won't work without this
NEWS_API_KEY=your_newsapi_key_here

# Daily schedule time in HH:MM format (24h, UTC)
SCHEDULE_TIME=07:00

# News topics (comma-separated keywords)
NEWS_TOPICS=technology,AI,programming
